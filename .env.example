# Database
DATABASE_URL=postgresql://p7erp:p7erp@localhost:5432/p7erp

# Auth
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Tenant: subdomain | header | path
TENANT_STRATEGY=header

# CORS (comma-separated origins, or leave empty to allow same-origin only)
CORS_ORIGINS=

# Redis (optional, for sessions/cache)
REDIS_URL=redis://localhost:6379/0

# App
API_V1_PREFIX=/api/v1
