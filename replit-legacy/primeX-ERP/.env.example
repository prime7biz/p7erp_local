# Prime7 ERP — Environment Variables
# Copy to .env and fill in values. NEVER commit .env itself.

DATABASE_URL=
PGHOST=
PGPORT=
PGUSER=
PGPASSWORD=
PGDATABASE=

JWT_SECRET=
SESSION_SECRET=
NODE_ENV=development

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5000

# Cookie domain (optional, for cross-site)
COOKIE_DOMAIN=

# AI Services (managed by Replit integrations)
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# Email
RESEND_API_KEY=
